{
	auto_https off
	servers {
		protocols h1
	}
}

:80 {
	encode gzip zstd

	header {
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		X-Frame-Options "SAMEORIGIN"
	}

	handle /up {
		header Content-Type "text/plain; charset=utf-8"
		respond `OK` 200
	}

	handle {
		reverse_proxy localhost:8090
	}
}
