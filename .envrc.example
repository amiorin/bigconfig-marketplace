# Google OAuth credentials. Applied to the `_pb_users_auth_` collection on
# every bootstrap by `pb_hooks/google_oauth.pb.js`; restart PocketBase after
# rotating. If either is empty the hook logs and leaves the existing
# provider config untouched.
export GOOGLE_CLIENT_ID=
export GOOGLE_CLIENT_SECRET=

# Where the browser/SDK reaches PocketBase. Inlined into the static JS
# bundle by Astro at build time, so this MUST be an absolute origin
# (scheme + host). An empty or relative value makes the PocketBase SDK
# emit page-path-relative URLs at runtime — e.g. on /login it calls
# /login/api/... instead of /api/... — which breaks Google SSO.
# - Dev: https://localhost (via Caddy).
# - CI: the prod PB origin so SSG fetches live data.
# - Prod: the deployed origin (override the Dockerfile build arg).
export PUBLIC_PB_URL=https://localhost

# Optional: raise the GitHub API rate limit for hook-side enrichment.
# Without this the unauthenticated limit (60 req/h) applies.
export GITHUB_TOKEN=

# Required for hooks to trigger a static-site rebuild after package
# approvals, updates, and the nightly GitHub-stats refresh.
# DISPATCH_REPO — target repository in "owner/repo" form that receives
#   the `repository_dispatch` event (event_type: rebuild-site).
# DISPATCH_PAT  — GitHub Personal Access Token with `repo` scope on that
#   repository (needed to POST /repos/{owner}/{repo}/dispatches).
# Without both vars the hooks log a warning and skip the dispatch.
export DISPATCH_REPO=
export DISPATCH_PAT=

# Make Node (Astro dev SSG fetch) trust Caddy's local CA.
export NODE_EXTRA_CA_CERTS="$HOME/Library/Application Support/Caddy/pki/authorities/local/root.crt"

# Litestream — dev replicates `pocketbase/pb_data/data.db` to your own S3 dev
# bucket so the prod restore + replicate path is exercised locally. The dev
# entrypoint (`entrypoint.dev.sh`) wraps PocketBase in `litestream replicate
# -exec`, so `hivemind` will fail to start the `pb` process unless these are
# set. To run dev without Litestream, comment out the `pb:` line in `Procfile`
# and run `cd pocketbase && pocketbase serve --dev` manually instead.
# Use a per-developer LITESTREAM_PATH prefix to avoid stomping on each other
# inside a shared bucket. LITESTREAM_DB_PATH is set automatically by
# entrypoint.dev.sh / entrypoint.sh — don't set it here.
export LITESTREAM_BUCKET=
export LITESTREAM_PATH=dev/$USER/data.db
export LITESTREAM_REGION=us-east-1
export LITESTREAM_ENDPOINT=
export LITESTREAM_ACCESS_KEY_ID=
export LITESTREAM_SECRET_ACCESS_KEY=
export LITESTREAM_SYNC_INTERVAL=1s
