# Where the build-time fetch and the browser SDK should reach PocketBase.
# - In dev, point at your local PB instance.
# - In CI, point at the prod PB so SSG fetches the live data.
# - At runtime in prod, the page is served same-origin from PB so '' works
#   (set this to '' in the deployed image).
PUBLIC_PB_URL=http://127.0.0.1:8090
