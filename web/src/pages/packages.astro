---
import Layout from '~/layouts/Layout.astro';
import PackageCard from '~/components/PackageCard.astro';
import { fetchApprovedPackages } from '~/lib/packages';
import { TAG_GROUPS } from '~/lib/tags';

const all = await fetchApprovedPackages();
---

<Layout title="Packages — BigConfig Marketplace">
  <section class="mx-auto max-w-6xl px-6 pt-20 pb-12">
    <div class="text-center">
      <div
        class="mb-4 inline-block text-xs font-semibold tracking-widest text-yellow-400 uppercase"
      >
        Packages
      </div>
      <h1
        class="text-4xl font-semibold tracking-tight text-white md:text-5xl"
      >
        Browse the shelf.
      </h1>
      <p class="mx-auto mt-4 max-w-2xl text-neutral-400">
        {all.length} community-built BigConfig packages. Filter by tag, or search by name.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-6 pb-12">
    <div class="rounded-2xl border border-neutral-800 bg-neutral-900/40 p-6">
      <input
        id="search-input"
        type="search"
        placeholder="Search by name or description…"
        class="w-full rounded-lg border border-neutral-700 bg-neutral-950 px-4 py-3 text-white placeholder-neutral-500 outline-none focus:border-yellow-400"
      />
      <div class="mt-6 space-y-4">
        {
          TAG_GROUPS.map((group) => (
            <div>
              <div class="mb-2 text-xs font-semibold tracking-wider text-neutral-500 uppercase">
                {group.label}
              </div>
              <div class="flex flex-wrap gap-2">
                {group.tags.map((t) => (
                  <button
                    type="button"
                    class="tag-filter rounded-full bg-neutral-800/80 px-2.5 py-0.5 text-xs text-neutral-300 transition hover:bg-neutral-700 data-[active=true]:bg-yellow-400 data-[active=true]:text-neutral-950"
                    data-tag={t}
                    data-active="false"
                  >
                    {t}
                  </button>
                ))}
              </div>
            </div>
          ))
        }
      </div>
      <div class="mt-4 flex items-center justify-between">
        <span id="result-count" class="text-xs text-neutral-500"
          >{all.length} packages</span
        >
        <button
          id="clear-filters"
          type="button"
          class="text-xs text-neutral-400 underline hover:text-yellow-400"
          >Clear filters</button
        >
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-6 pb-24">
    {
      all.length === 0 ? (
        <div class="rounded-2xl border border-neutral-800 bg-neutral-900/40 p-10 text-center text-neutral-400">
          <p>No packages yet — add the first directory entry.</p>
          <a
            href="/submit"
            class="mt-6 inline-block rounded-full bg-yellow-400 px-6 py-3 text-sm font-semibold text-neutral-950 hover:bg-yellow-300"
          >
            Add a package
          </a>
        </div>
      ) : (
        <div id="grid" class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {all.map((p) => (
            <div
              class="package-card-wrapper contents"
              data-name={p.name.toLowerCase()}
              data-description={(p.description || '').toLowerCase()}
              data-tags={(p.tags || []).join(',')}
            >
              <PackageCard pkg={p} />
            </div>
          ))}
        </div>
      )
    }
    <div
      id="empty-state"
      class="hidden rounded-2xl border border-neutral-800 bg-neutral-900/40 p-10 text-center text-neutral-400"
    >
      No packages match these filters.
    </div>
  </section>
</Layout>

<script>
  const search = document.getElementById('search-input') as HTMLInputElement;
  const grid = document.getElementById('grid');
  const empty = document.getElementById('empty-state');
  const count = document.getElementById('result-count');
  const clearBtn = document.getElementById('clear-filters');
  const filterBtns = Array.from(
    document.querySelectorAll<HTMLButtonElement>('.tag-filter')
  );
  const cards = Array.from(
    document.querySelectorAll<HTMLElement>('.package-card-wrapper')
  );
  const total = cards.length;
  const activeTags = new Set<string>();

  function apply() {
    const q = (search?.value ?? '').trim().toLowerCase();
    let shown = 0;
    for (const card of cards) {
      const name = card.dataset.name ?? '';
      const desc = card.dataset.description ?? '';
      const tags = (card.dataset.tags ?? '').split(',').filter(Boolean);
      const matchesQuery = !q || name.includes(q) || desc.includes(q);
      const matchesTags =
        activeTags.size === 0 || [...activeTags].every((t) => tags.includes(t));
      const visible = matchesQuery && matchesTags;
      card.classList.toggle('hidden', !visible);
      if (visible) shown++;
    }
    if (count) count.textContent = `${shown} of ${total} packages`;
    if (grid && empty) {
      grid.classList.toggle('hidden', shown === 0);
      empty.classList.toggle('hidden', shown !== 0);
    }
  }

  search?.addEventListener('input', apply);
  for (const btn of filterBtns) {
    btn.addEventListener('click', () => {
      const tag = btn.dataset.tag!;
      if (activeTags.has(tag)) {
        activeTags.delete(tag);
        btn.dataset.active = 'false';
      } else {
        activeTags.add(tag);
        btn.dataset.active = 'true';
      }
      apply();
    });
  }
  clearBtn?.addEventListener('click', () => {
    activeTags.clear();
    for (const btn of filterBtns) btn.dataset.active = 'false';
    if (search) search.value = '';
    apply();
  });
</script>
