---
import Layout from '~/layouts/Layout.astro';

const packageBbEdn = `;; bb.edn
{:deps {io.github.amiorin/alice {:git/sha "9c214edce47419297e6bd8212a63bb0ab93bcf86"}}
 :tasks
 {:requires ([io.github.amiorin.alice.package :as package])
  alice {:doc  "Manage the Alice package"
         :task (package/alice* *command-line-args*)}}}`;

const packageRun = `# Provision infrastructure and software
bb alice create

# Tear it down
bb alice delete`;

const onceBbEdn = `;; bb.edn
{:deps  {io.github.amiorin/once {:git/url "https://github.com/amiorin/once"
                                 :git/sha "8ffbbc2ea0974365575c7ee44b7d890e69447144"}}
 :tasks {:requires ([io.github.amiorin.once.package :as pkg])
         once {:doc  "bb once create | bb once delete"
               :task (pkg/once*
                      *command-line-args*
                      {:big-config.workflow/params
                       {:once {:applications [{:host  "www.example.com"
                                               :image "ghcr.io/me/my-app:latest"}]}
                        :provider-compute "hcloud"
                        :provider-dns     "cloudflare"
                        :provider-smtp    "resend"}})}}}`;

const onceRun = `bb once create
bb once delete`;

const sections = [
  { id: 'agentic', label: 'Agentic by default' },
  { id: 'use-marketplace', label: 'How to use the Marketplace' },
  { id: 'bigconfig', label: 'What is BigConfig' },
  { id: 'bb-edn', label: 'What is bb.edn' },
  { id: 'bigconfig-package', label: 'What is a BigConfig Package' },
  { id: 'once-package', label: 'What is the BigConfig package once' },
  { id: 'once', label: 'What is ONCE' },
  { id: 'once-application', label: 'What is a ONCE application' },
];

const agenticPoints = [
  {
    title: 'Your agent writes the bb.edn',
    body: 'Describe the deployment in plain English. The agent refines the plan and produces a single bb.edn — you never have to write Clojure yourself.',
  },
  {
    title: 'Repackage Terraform projects',
    body: 'Point your agent at an existing Terraform project and ask it to convert the codebase into a BigConfig package — you bring the runbooks, the agent ports them.',
  },
  {
    title: 'Deploy ONCE apps for you',
    body: 'Hand the agent a Docker image and a domain. It drives the BigConfig once package to provision the server, wire DNS and SMTP, and ship the container.',
  },
  {
    title: 'No coding required',
    body: 'You do not write Clojure, Terraform, Ansible, or YAML. You describe what you want; the agent operates BigConfig on your behalf.',
  },
];
---

<Layout title="Documentation — BigConfig Marketplace">
  <section class="mx-auto max-w-3xl px-6 pt-20 pb-12 text-center">
    <div
      class="mb-4 inline-block text-xs font-semibold tracking-widest text-yellow-400 uppercase"
    >
      Documentation
    </div>
    <h1 class="text-4xl font-semibold tracking-tight text-white md:text-5xl">
      How the Marketplace fits together.
    </h1>
    <p class="mx-auto mt-4 max-w-xl text-neutral-400">
      A short tour of BigConfig, BigConfig Packages, the <code
        class="rounded bg-neutral-800 px-1.5 py-0.5 font-mono text-sm text-yellow-400"
        >once</code
      > package, ONCE, and ONCE applications — and how they combine to make
      this site work.
    </p>
  </section>

  <nav class="mx-auto max-w-3xl px-6 pb-16">
    <div class="rounded-2xl border border-neutral-800 bg-neutral-900/40 p-6">
      <div
        class="mb-3 text-xs font-semibold tracking-wider text-neutral-500 uppercase"
      >
        On this page
      </div>
      <ul class="grid gap-2 text-sm md:grid-cols-2">
        {
          sections.map((s) => (
            <li>
              <a
                href={`#${s.id}`}
                class="text-neutral-200 transition hover:text-yellow-400"
              >
                {s.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </nav>

  <section id="agentic" class="mx-auto max-w-3xl px-6 pb-20">
    <h2 class="text-3xl font-semibold tracking-tight text-white">
      Agentic by default
    </h2>
    <p class="mt-6 leading-relaxed text-neutral-300">
      BigConfig is built so an LLM agent can do the work for you. Every
      artifact in the workflow — from the Clojure configuration to the
      deployment commands — is something the agent reads, writes, and runs.
      You stay in plain English.
    </p>
    <div class="mt-8 grid gap-4 md:grid-cols-2">
      {
        agenticPoints.map((p) => (
          <div class="rounded-2xl border border-neutral-800 bg-neutral-900/40 p-6">
            <h3 class="text-base font-semibold text-white">{p.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-neutral-400">
              {p.body}
            </p>
          </div>
        ))
      }
    </div>
  </section>

  <section id="use-marketplace" class="mx-auto max-w-3xl px-6 pb-20">
    <h2 class="text-3xl font-semibold tracking-tight text-white">
      How to use the Marketplace
    </h2>
    <p class="mt-6 leading-relaxed text-neutral-300">
      BigConfig Marketplace is a community catalog of two kinds of
      submissions — <a
        href="/packages"
        class="text-yellow-400 hover:underline">BigConfig Packages</a
      >
      and
      <a href="/applications" class="text-yellow-400 hover:underline"
        >ONCE applications</a
      >. You can browse anonymously; signing in with Google is only required
      to submit your own.
    </p>
    <p class="mt-4 leading-relaxed text-neutral-300">
      Every new entry starts in a <em>pending</em> state, visible only to
      its submitter on the <a
        href="/me/packages"
        class="text-yellow-400 hover:underline">My packages</a
      >
      and <a
        href="/me/applications"
        class="text-yellow-400 hover:underline">My applications</a
      > pages. Once an admin approves it, it lands in the public catalog and
      its GitHub metadata (description, stars, last push, OG image) is
      refreshed automatically — including a nightly job that keeps the
      counts current.
    </p>
    <p class="mt-4 leading-relaxed text-neutral-300">
      To submit a package, point the form at any public GitHub repository
      that contains a BigConfig package. To submit a ONCE application,
      provide a publicly pullable Docker image reference. The shape of each
      submission is described in the dedicated sections below.
    </p>
  </section>

  <section id="bigconfig" class="mx-auto max-w-3xl px-6 pb-20">
    <h2 class="text-3xl font-semibold tracking-tight text-white">
      What is BigConfig
    </h2>
    <p class="mt-6 leading-relaxed text-neutral-300">
      <a
        href="https://bigconfig.it"
        class="text-yellow-400 hover:underline"
        target="_blank"
        rel="noopener">BigConfig</a
      > is the first <em>agentic</em> package manager — a Clojure/Babashka
      framework for delivering infrastructure and software as a single,
      cohesive unit. It is designed so that you don't need to learn it
      yourself: an LLM agent can operate it on your behalf from a plain
      English description.
    </p>
    <p class="mt-4 leading-relaxed text-neutral-300">
      The most radical design choice in BigConfig is what it lacks:
      <strong class="text-white">a dedicated CLI</strong>. Instead of
      shipping yet another binary, BigConfig is consumed as a library
      through Babashka tasks. Each package author defines their own CLI
      surface in <code
        class="rounded bg-neutral-800 px-1.5 py-0.5 font-mono text-sm text-yellow-400"
        >bb.edn</code
      >, which means end-users can compose, customize, and embed packages
      without fighting binary boundaries.
    </p>
    <p class="mt-4 leading-relaxed text-neutral-300">
      Practically, BigConfig spans three environments — the shell (for
      ad-hoc commands), the REPL (for live debugging without
      edit-compile-fail loops), and the library (for deep automation
      embedded in your own code). The same package works in all three.
    </p>
  </section>

  <section id="bb-edn" class="mx-auto max-w-3xl px-6 pb-20">
    <h2 class="text-3xl font-semibold tracking-tight text-white">
      What is <code
        class="rounded bg-neutral-800 px-1.5 py-0.5 font-mono text-yellow-400"
        >bb.edn</code
      >
    </h2>
    <p class="mt-6 leading-relaxed text-neutral-300">
      <code
        class="rounded bg-neutral-800 px-1.5 py-0.5 font-mono text-sm text-yellow-400"
        >bb.edn</code
      > is the file Babashka reads to know what to do. It is the Clojure
      counterpart of the <code
        class="rounded bg-neutral-800 px-1.5 py-0.5 font-mono text-sm text-yellow-400"
        >scripts</code
      > block in <code
        class="rounded bg-neutral-800 px-1.5 py-0.5 font-mono text-sm text-yellow-400"
        >package.json</code
      >: a list of named tasks bound to Clojure code, alongside the
      dependencies those tasks need. Where a Node project lets you type
      <code
        class="rounded bg-neutral-800 px-1.5 py-0.5 font-mono text-sm text-yellow-400"
        >npm run deploy</code
      >, a BigConfig project lets you type <code
        class="rounded bg-neutral-800 px-1.5 py-0.5 font-mono text-sm text-yellow-400"
        >bb deploy</code
      >.
    </p>
    <p class="mt-4 leading-relaxed text-neutral-300">
      Two properties make <code
        class="rounded bg-neutral-800 px-1.5 py-0.5 font-mono text-sm text-yellow-400"
        >bb.edn</code
      > central to the agentic flow:
    </p>
    <ul
      class="mt-4 list-disc space-y-2 pl-6 leading-relaxed text-neutral-300"
    >
      <li>
        <strong class="text-white">Generated by your agent.</strong> You do
        not write it by hand. Your agent turns a plain-English description
        — domain, image, provider, region, credentials — into a single <code
          class="rounded bg-neutral-800 px-1.5 py-0.5 font-mono text-sm text-yellow-400"
          >bb.edn</code
        > file.
      </li>
      <li>
        <strong class="text-white">Invoked by your agent.</strong> Once the
        file exists, the agent runs the tasks (<code
          class="rounded bg-neutral-800 px-1.5 py-0.5 font-mono text-sm text-yellow-400"
          >bb once create</code
        >, <code
          class="rounded bg-neutral-800 px-1.5 py-0.5 font-mono text-sm text-yellow-400"
          >bb alice create</code
        >, and so on), watches the output, and iterates if something
        fails.
      </li>
    </ul>
    <p class="mt-4 leading-relaxed text-neutral-300">
      A concrete example of a <code
        class="rounded bg-neutral-800 px-1.5 py-0.5 font-mono text-sm text-yellow-400"
        >bb.edn</code
      > appears in the next section.
    </p>
  </section>

  <section id="bigconfig-package" class="mx-auto max-w-3xl px-6 pb-20">
    <h2 class="text-3xl font-semibold tracking-tight text-white">
      What is a BigConfig Package
    </h2>
    <p class="mt-6 leading-relaxed text-neutral-300">
      A <strong class="text-white">BigConfig Package</strong> is a standard
      Clojure repository whose entry point is a <em>workflow function</em>
      authored with the BigConfig Workflow library. The package author
      defines the lifecycle (<code
        class="rounded bg-neutral-800 px-1.5 py-0.5 font-mono text-sm text-yellow-400"
        >create</code
      >, <code
        class="rounded bg-neutral-800 px-1.5 py-0.5 font-mono text-sm text-yellow-400"
        >delete</code
      >, and any custom steps), the providers it can target, and the
      parameters it exposes.
    </p>
    <p class="mt-4 leading-relaxed text-neutral-300">
      To use a package, you add it as a dependency in your <code
        class="rounded bg-neutral-800 px-1.5 py-0.5 font-mono text-sm text-yellow-400"
        >bb.edn</code
      > and bind it to a Babashka task:
    </p>
    <pre
      class="mt-4 overflow-x-auto rounded-2xl border border-neutral-800 bg-neutral-900/40 p-6 text-sm leading-relaxed"><code class="font-mono text-neutral-300">{packageBbEdn}</code></pre>
    <p class="mt-4 leading-relaxed text-neutral-300">
      Then run the standardized lifecycle commands. We use <code
        class="rounded bg-neutral-800 px-1.5 py-0.5 font-mono text-sm text-yellow-400"
        >create</code
      >
      rather than <code
        class="rounded bg-neutral-800 px-1.5 py-0.5 font-mono text-sm text-yellow-400"
        >install</code
      > to reflect that infrastructure is actively provisioned during delivery,
      not just unpacked locally.
    </p>
    <pre
      class="mt-4 overflow-x-auto rounded-2xl border border-neutral-800 bg-neutral-900/40 p-6 text-sm leading-relaxed"><code class="font-mono text-neutral-300">{packageRun}</code></pre>
    <p class="mt-4 leading-relaxed text-neutral-300">
      Because everything goes through Babashka, startup is near-instant —
      ideal for both CI/CD and the inner-loop iterations of an agent
      reading and writing config.
    </p>
  </section>

  <section id="once-package" class="mx-auto max-w-3xl px-6 pb-20">
    <h2 class="text-3xl font-semibold tracking-tight text-white">
      What is the BigConfig package <code
        class="rounded bg-neutral-800 px-1.5 py-0.5 font-mono text-yellow-400"
        >once</code
      >
    </h2>
    <p class="mt-6 leading-relaxed text-neutral-300">
      <a
        href="/packages/amiorin/once"
        class="text-yellow-400 hover:underline"><code
          class="rounded bg-neutral-800 px-1.5 py-0.5 font-mono text-sm text-yellow-400"
          >once</code
        ></a
      > is the BigConfig package that turns any ONCE application into a
      single-command deployment. It provisions a server (Hetzner Cloud,
      Oracle Cloud, or a host you bring yourself), wires up Cloudflare DNS,
      configures Resend SMTP end-to-end (DKIM and SPF included), and runs
      Ansible playbooks to install Docker, the firewall, and TLS.
    </p>
    <p class="mt-4 leading-relaxed text-neutral-300">
      The complete bb.edn for a deployment looks like this — note how a
      single ONCE application is described by a host plus a public Docker
      image:
    </p>
    <pre
      class="mt-4 overflow-x-auto rounded-2xl border border-neutral-800 bg-neutral-900/40 p-6 text-sm leading-relaxed"><code class="font-mono text-neutral-300">{onceBbEdn}</code></pre>
    <p class="mt-4 leading-relaxed text-neutral-300">
      With that file in place, the lifecycle is two commands:
    </p>
    <pre
      class="mt-4 overflow-x-auto rounded-2xl border border-neutral-800 bg-neutral-900/40 p-6 text-sm leading-relaxed"><code class="font-mono text-neutral-300">{onceRun}</code></pre>
    <p class="mt-4 leading-relaxed text-neutral-300">
      Both commands are agent-operable and reversible: there is no
      "configure manually after first boot" step, and tearing the
      deployment down leaves no orphaned resources behind.
    </p>
  </section>

  <section id="once" class="mx-auto max-w-3xl px-6 pb-20">
    <h2 class="text-3xl font-semibold tracking-tight text-white">
      What is ONCE
    </h2>
    <p class="mt-6 leading-relaxed text-neutral-300">
      <strong class="text-white">ONCE</strong> is Basecamp's open-source
      platform for installing and managing Docker-based web applications,
      with the explicit goal of making self-hosting as simple as possible.
      The codebase lives at <a
        href="https://github.com/basecamp/once"
        target="_blank"
        rel="noopener"
        class="text-yellow-400 hover:underline">github.com/basecamp/once</a
      >.
    </p>
    <p class="mt-4 leading-relaxed text-neutral-300">
      The tool bundles three things you would otherwise wire up yourself: a
      one-line installer that drops the binary onto the host (and Docker,
      if needed), a TUI dashboard for monitoring and operating each
      application, and a CLI suite that is convenient for humans and
      especially well-suited for AI agents. On top of that it provides
      automatic updates, backups, and system information.
    </p>
    <p class="mt-4 leading-relaxed text-neutral-300">
      ONCE runs on Linux and macOS, and is designed to work on whatever
      hardware fits the deployment — a physical server, a cloud VPS, a
      Raspberry Pi, or a laptop. Out of the box it ships with the
      37signals applications, and it can install any compatible Docker
      image as well, including third-party apps and custom forks.
    </p>
    <div
      class="mt-6 rounded-2xl border border-neutral-800 bg-neutral-900/40 p-6 text-sm leading-relaxed text-neutral-300"
    >
      <div
        class="mb-2 text-xs font-semibold tracking-widest text-yellow-400 uppercase"
      >
        At a glance
      </div>
      <ul class="list-disc space-y-1 pl-5">
        <li>One-line installer: <code
            class="rounded bg-neutral-800 px-1.5 py-0.5 font-mono text-xs text-yellow-400"
            >curl https://get.once.com | sh</code
          >.</li>
        <li>TUI dashboard plus an agent-friendly CLI for day-2 operations.</li>
        <li>Automatic updates, backups, and system information built in.</li>
        <li>Runs on Linux and macOS — anything from a Raspberry Pi to a cloud VPS.</li>
        <li>37signals apps included; any compatible Docker image works.</li>
      </ul>
    </div>
    <p class="mt-6 leading-relaxed text-neutral-300">
      What ONCE deliberately leaves outside its scope is the host itself —
      the cloud account, the server, the DNS records, the SMTP credentials,
      the firewall. That is exactly the gap the BigConfig <code
        class="rounded bg-neutral-800 px-1.5 py-0.5 font-mono text-sm text-yellow-400"
        >once</code
      > package fills, and where your agent does the work for you.
    </p>
  </section>

  <section id="once-application" class="mx-auto max-w-3xl px-6 pb-20">
    <h2 class="text-3xl font-semibold tracking-tight text-white">
      What is a ONCE application
    </h2>
    <p class="mt-6 leading-relaxed text-neutral-300">
      A <strong class="text-white">ONCE application</strong> is a Docker
      container that follows a small contract:
    </p>
    <ul
      class="mt-4 list-disc space-y-2 pl-6 leading-relaxed text-neutral-300"
    >
      <li>
        It serves HTTP on port <code
          class="rounded bg-neutral-800 px-1.5 py-0.5 font-mono text-sm text-yellow-400"
          >80</code
        >.
      </li>
      <li>
        It exposes a <code
          class="rounded bg-neutral-800 px-1.5 py-0.5 font-mono text-sm text-yellow-400"
          >/up</code
        > healthcheck endpoint (returning <code
          class="rounded bg-neutral-800 px-1.5 py-0.5 font-mono text-sm text-yellow-400"
          >200 OK</code
        > when the app is ready).
      </li>
      <li>
        It persists all state under <code
          class="rounded bg-neutral-800 px-1.5 py-0.5 font-mono text-sm text-yellow-400"
          >/storage</code
        >, which the host mounts as a durable volume.
      </li>
      <li>
        Its image is publicly pullable (Docker Hub, GHCR, or any other
        public registry).
      </li>
    </ul>
    <p class="mt-4 leading-relaxed text-neutral-300">
      That's the whole shape. Any image that conforms can be deployed by
      the <code
        class="rounded bg-neutral-800 px-1.5 py-0.5 font-mono text-sm text-yellow-400"
        >once</code
      > package, listed in this marketplace as a ONCE application, and
      operated by an agent.
    </p>
  </section>

  <section class="mx-auto max-w-3xl px-6 pb-24">
    <div
      class="rounded-3xl border border-yellow-400/30 bg-yellow-400/5 p-10 md:p-12"
    >
      <div
        class="mb-3 text-xs font-semibold tracking-widest text-yellow-400 uppercase"
      >
        It's turtles all the way down
      </div>
      <h2 class="text-2xl font-semibold tracking-tight text-white md:text-3xl">
        BigConfig Marketplace is itself a ONCE application.
      </h2>
      <p class="mt-4 leading-relaxed text-neutral-300">
        This site is a single Docker image bundling a PocketBase backend
        with a static Astro frontend served from <code
          class="rounded bg-neutral-800 px-1.5 py-0.5 font-mono text-sm text-yellow-400"
          >pb_public</code
        >. It serves HTTP on <code
          class="rounded bg-neutral-800 px-1.5 py-0.5 font-mono text-sm text-yellow-400"
          >:80</code
        >, exposes <code
          class="rounded bg-neutral-800 px-1.5 py-0.5 font-mono text-sm text-yellow-400"
          >/up</code
        >, and stores its database under <code
          class="rounded bg-neutral-800 px-1.5 py-0.5 font-mono text-sm text-yellow-400"
          >/storage</code
        > — exactly the contract above.
      </p>
      <p class="mt-4 leading-relaxed text-neutral-300">
        It's deployed using the BigConfig <a
          href="/packages/amiorin/once"
          class="text-yellow-400 hover:underline"><code
            class="rounded bg-neutral-800 px-1.5 py-0.5 font-mono text-sm text-yellow-400"
            >once</code
          ></a
        > package — the same package this Marketplace catalogs.
      </p>
    </div>
  </section>
</Layout>
