---
import Layout from '~/layouts/Layout.astro';
---

<Layout title="Sign in — Made with BigConfig">
  <section class="mx-auto max-w-md px-6 pt-20 pb-24">
    <div class="rounded-2xl border border-neutral-800 bg-neutral-900/40 p-10">
      <div
        class="mb-4 inline-block text-xs font-semibold tracking-widest text-yellow-400 uppercase"
      >
        Sign in
      </div>
      <h1 class="text-3xl font-semibold tracking-tight text-white">
        Sign in to publish.
      </h1>
      <p class="mt-3 text-sm text-neutral-400">
        Authentication is handled by Google. We only use your name and avatar
        to attribute your submissions.
      </p>
      <button
        id="google-signin"
        type="button"
        class="mt-8 flex w-full items-center justify-center gap-3 rounded-full bg-yellow-400 px-6 py-4 text-base font-semibold text-neutral-950 transition hover:bg-yellow-300 disabled:opacity-60"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" aria-hidden="true">
          <path
            fill="currentColor"
            d="M21.6 12.227c0-.71-.064-1.39-.182-2.045H12v3.868h5.39a4.605 4.605 0 0 1-2 3.022v2.51h3.232c1.89-1.745 2.978-4.31 2.978-7.355z"></path>
          <path
            fill="currentColor"
            d="M12 22c2.7 0 4.964-.895 6.62-2.418l-3.232-2.51c-.895.6-2.04.955-3.388.955-2.605 0-4.81-1.76-5.595-4.123H3.064v2.59A9.996 9.996 0 0 0 12 22z"></path>
          <path
            fill="currentColor"
            d="M6.405 13.904a6.005 6.005 0 0 1 0-3.807V7.507H3.064a9.996 9.996 0 0 0 0 8.986l3.34-2.59z"></path>
          <path
            fill="currentColor"
            d="M12 5.97c1.468 0 2.786.505 3.823 1.496l2.868-2.868C16.96 2.99 14.696 2 12 2A9.996 9.996 0 0 0 3.064 7.507l3.34 2.59C7.19 7.73 9.394 5.97 12 5.97z"
          ></path>
        </svg>
        Continue with Google
      </button>
      <p
        id="login-status"
        class="mt-4 hidden text-center text-sm text-neutral-400"
      >
      </p>
    </div>
  </section>
</Layout>

<script>
  import PocketBase from 'pocketbase';

  const pb = new PocketBase(import.meta.env.PUBLIC_PB_URL || '');
  const button = document.getElementById('google-signin') as HTMLButtonElement;
  const status = document.getElementById('login-status') as HTMLElement;

  if (pb.authStore.isValid) {
    location.href = '/me/packages';
  }

  button?.addEventListener('click', async () => {
    button.disabled = true;
    status.classList.remove('hidden');
    status.textContent = 'Opening Google…';
    try {
      const result = await pb
        .collection('users')
        .authWithOAuth2({ provider: 'google' });
      const meta = (result as any)?.meta || {};
      const avatarUrl = meta.avatarURL || meta.avatarUrl || '';
      if (avatarUrl) localStorage.setItem('user_avatar_url', avatarUrl);
      status.textContent = 'Signed in. Redirecting…';
      const next =
        new URLSearchParams(location.search).get('next') || '/me/packages';
      location.href = next;
    } catch (err) {
      console.error(err);
      status.textContent =
        'Sign-in failed. Try again or check that Google OAuth is configured.';
      button.disabled = false;
    }
  });
</script>
