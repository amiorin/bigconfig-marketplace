---
import Layout from '~/layouts/Layout.astro';
import TagChip from '~/components/TagChip.astro';
import { fetchApprovedPackages, ownerRepo } from '~/lib/packages';
import type { PackageRecord } from '~/lib/pb';

export async function getStaticPaths() {
  const all = await fetchApprovedPackages();
  return all.map((p) => {
    const { owner, repo } = ownerRepo(p.name);
    return {
      params: { owner, repo },
      props: { pkg: p },
    };
  });
}

interface Props {
  pkg: PackageRecord;
}

const { pkg } = Astro.props;
const submitterName = pkg.expand?.submitter?.name || pkg.expand?.submitter?.id || 'unknown';
const pushed = pkg.pushed_at
  ? new Date(pkg.pushed_at).toLocaleDateString(undefined, {
      year: 'numeric',
      month: 'short',
      day: 'numeric',
    })
  : null;

const usePrompt = `Use the BigConfig Package at ${pkg.github_url}.

Generate a bb.edn that adds this package as a dependency and binds it to a Babashka task. Read the package documentation to discover the task name, required parameters, supported providers, and lifecycle commands.

Ask me for every missing value before writing or running anything, including provider choices, regions, credentials, domains, and package-specific parameters.

After I confirm the generated bb.edn, run the package lifecycle with bb <task> create, watch the output, and iterate on failures. Also tell me how to tear it down with the matching bb <task> delete command.`;
---

<Layout title={`${pkg.name} — BigConfig Marketplace`} description={pkg.description}>
  <section class="mx-auto max-w-6xl px-6 pt-20 pb-12">
    <a
      href="/packages"
      class="text-sm text-neutral-400 hover:text-yellow-400">← All packages</a
    >
    <div class="mt-6 flex flex-wrap items-start justify-between gap-6">
      <div>
        <h1
          class="text-4xl font-semibold tracking-tight text-white md:text-5xl"
        >
          {pkg.name}
        </h1>
        <p class="mt-2 text-sm text-neutral-500">submitted by {submitterName}</p>
        {
          pkg.tags && pkg.tags.length > 0 && (
            <div class="mt-4 flex flex-wrap gap-2">
              {pkg.tags.map((t) => (
                <TagChip tag={t} />
              ))}
            </div>
          )
        }
      </div>
      <a
        href={pkg.github_url}
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-full bg-yellow-400 px-6 py-3 text-sm font-semibold text-neutral-950 transition hover:bg-yellow-300"
        >View on GitHub →</a
      >
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-6 pb-24">
    <div class="grid gap-8 md:grid-cols-3">
      <div class="md:col-span-2">
        <div
          class="rounded-2xl border border-neutral-800 bg-neutral-900/40 p-8"
        >
          <h2 class="text-lg font-semibold text-white">About</h2>
          <p class="mt-3 leading-relaxed text-neutral-300">
            {pkg.description || 'No description provided.'}
          </p>
        </div>
        <div
          class="mt-6 rounded-2xl border border-neutral-800 bg-neutral-900/40 p-8"
        >
          <div class="flex items-center justify-between gap-4">
            <h2 class="text-lg font-semibold text-white">Use it</h2>
            <button
              id="copy-use-prompt"
              type="button"
              data-prompt={usePrompt}
              class="rounded-full border border-neutral-700 px-3 py-1 text-xs font-semibold text-neutral-200 hover:border-yellow-400 hover:text-yellow-400"
            >
              Copy prompt
            </button>
          </div>
          <p class="mt-3 text-sm text-neutral-400">
            Give this prompt to your agent to generate the bb.edn, ask for
            missing values, and operate the package lifecycle.
          </p>
          <pre
            class="mt-4 whitespace-pre-wrap rounded-lg border border-neutral-800 bg-neutral-950 p-3 text-xs leading-relaxed text-neutral-300"><code>{usePrompt}</code></pre>
          <p class="mt-4 text-sm text-neutral-400">
            The prompt follows the documented <a
              href="/documentation#bigconfig-package"
              class="text-yellow-400 hover:underline">BigConfig Package</a
            > flow.
          </p>
        </div>
        {
          pkg.og_image && (
            <div class="mt-6 overflow-hidden rounded-2xl border border-neutral-800">
              <img
                src={pkg.og_image}
                alt={`${pkg.name} preview`}
                class="w-full"
                loading="lazy"
              />
            </div>
          )
        }
      </div>
      <aside class="space-y-4">
        <div class="rounded-2xl border border-neutral-800 bg-neutral-900/40 p-6">
          <div class="text-xs font-semibold tracking-widest text-neutral-500 uppercase">
            Repository
          </div>
          <dl class="mt-3 space-y-3 text-sm">
            <div class="flex justify-between gap-4">
              <dt class="text-neutral-400">Stars</dt>
              <dd class="text-white">{pkg.stars}</dd>
            </div>
            {
              pkg.default_branch && (
                <div class="flex justify-between gap-4">
                  <dt class="text-neutral-400">Branch</dt>
                  <dd class="text-white font-mono text-xs">
                    {pkg.default_branch}
                  </dd>
                </div>
              )
            }
            {
              pushed && (
                <div class="flex justify-between gap-4">
                  <dt class="text-neutral-400">Last push</dt>
                  <dd class="text-white">{pushed}</dd>
                </div>
              )
            }
          </dl>
        </div>
      </aside>
    </div>
  </section>
</Layout>

<script>
  const btn = document.getElementById('copy-use-prompt') as HTMLButtonElement | null;
  btn?.addEventListener('click', async () => {
    const prompt = btn.dataset.prompt ?? '';
    try {
      await navigator.clipboard.writeText(prompt);
      const prev = btn.textContent;
      btn.textContent = 'Copied';
      setTimeout(() => (btn.textContent = prev), 1200);
    } catch {}
  });
</script>
