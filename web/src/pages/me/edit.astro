---
import Layout from '~/layouts/Layout.astro';
import { TAG_GROUPS } from '~/lib/tags';
---

<Layout title="Edit package — BigConfig Marketplace">
  <section class="mx-auto max-w-3xl px-6 pt-20 pb-24">
    <a href="/me/packages" class="text-sm text-neutral-400 hover:text-yellow-400"
      >← Back to my packages</a
    >
    <div class="mt-6">
      <div
        class="mb-4 inline-block text-xs font-semibold tracking-widest text-yellow-400 uppercase"
      >
        Edit
      </div>
      <h1 class="text-4xl font-semibold tracking-tight text-white md:text-5xl">
        <span id="pkg-name">Package</span>
      </h1>
    </div>

    <div
      id="auth-gate"
      class="mt-12 hidden rounded-2xl border border-neutral-800 bg-neutral-900/40 p-10 text-center"
    >
      <p class="text-neutral-300">Sign in to edit your packages.</p>
      <a
        href="/login"
        class="mt-6 inline-block rounded-full bg-yellow-400 px-6 py-3 text-sm font-semibold text-neutral-950 hover:bg-yellow-300"
        >Sign in</a
      >
    </div>

    <div id="loading" class="mt-12 text-center text-neutral-500">Loading…</div>
    <div
      id="error"
      class="mt-12 hidden rounded-2xl border border-neutral-800 bg-neutral-900/40 p-10 text-center text-neutral-300"
    >
    </div>

    <form
      id="edit-form"
      class="mt-12 hidden grid gap-5 rounded-2xl border border-neutral-800 bg-neutral-900/40 p-8 md:p-10"
    >
      <label class="block text-sm">
        <span class="mb-2 block font-medium text-neutral-200">GitHub URL</span>
        <input
          name="github_url"
          type="url"
          disabled
          class="w-full rounded-lg border border-neutral-800 bg-neutral-950/50 px-4 py-3 text-neutral-400 outline-none"
        />
        <span class="mt-1 block text-xs text-neutral-500"
          >URL is locked once submitted. Delete and re-submit if you need a
          different repo.</span
        >
      </label>
      <label class="block text-sm">
        <span class="mb-2 block font-medium text-neutral-200">Description</span>
        <textarea
          name="description"
          rows="3"
          class="w-full rounded-lg border border-neutral-700 bg-neutral-950 px-4 py-3 text-white placeholder-neutral-500 outline-none focus:border-yellow-400"
        ></textarea>
      </label>
      <div>
        <span class="mb-2 block text-sm font-medium text-neutral-200">Tags</span
        >
        <div class="space-y-3">
          {
            TAG_GROUPS.map((group) => (
              <div>
                <div class="mb-1.5 text-xs font-semibold tracking-wider text-neutral-500 uppercase">
                  {group.label}
                </div>
                <div class="flex flex-wrap gap-2">
                  {group.tags.map((t) => (
                    <label class="cursor-pointer">
                      <input
                        type="checkbox"
                        name="tags"
                        value={t}
                        class="peer sr-only"
                      />
                      <span class="rounded-full bg-neutral-800/80 px-2.5 py-0.5 text-xs text-neutral-300 transition peer-checked:bg-yellow-400 peer-checked:text-neutral-950">
                        {t}
                      </span>
                    </label>
                  ))}
                </div>
              </div>
            ))
          }
        </div>
      </div>
      <div class="flex flex-wrap gap-3">
        <button
          type="submit"
          class="rounded-full bg-yellow-400 px-6 py-3 text-sm font-semibold text-neutral-950 transition hover:bg-yellow-300 disabled:opacity-60"
          >Save changes</button
        >
        <button
          type="button"
          id="delete-btn"
          class="rounded-full border border-red-500/40 px-6 py-3 text-sm font-semibold text-red-300 transition hover:border-red-400 hover:bg-red-500/10"
          >Delete package</button
        >
      </div>
      <p
        id="form-status"
        class="hidden text-center text-sm text-neutral-400"
      >
      </p>
    </form>
  </section>
</Layout>

<script>
  import PocketBase from 'pocketbase';
  import { formatPbError } from '../../lib/pb';

  const pb = new PocketBase(import.meta.env.PUBLIC_PB_URL || '');
  const gate = document.getElementById('auth-gate')!;
  const loading = document.getElementById('loading')!;
  const errorBox = document.getElementById('error')!;
  const form = document.getElementById('edit-form') as HTMLFormElement;
  const status = document.getElementById('form-status')!;
  const nameEl = document.getElementById('pkg-name')!;
  const deleteBtn = document.getElementById('delete-btn')!;

  const id = new URLSearchParams(location.search).get('id') || '';

  if (!id) {
    loading.classList.add('hidden');
    errorBox.classList.remove('hidden');
    errorBox.textContent = 'No package id in URL.';
  } else if (!pb.authStore.isValid) {
    loading.classList.add('hidden');
    gate.classList.remove('hidden');
  } else {
    load();
  }

  async function load() {
    try {
      const pkg: any = await pb.collection('packages').getOne(id);
      const me = pb.authStore.record;
      if (pkg.submitter !== me?.id) {
        loading.classList.add('hidden');
        errorBox.classList.remove('hidden');
        errorBox.textContent = 'You can only edit packages you submitted.';
        return;
      }
      nameEl.textContent = pkg.name;
      (form.elements.namedItem('github_url') as HTMLInputElement).value =
        pkg.github_url;
      (form.elements.namedItem('description') as HTMLTextAreaElement).value =
        pkg.description || '';
      const tags: string[] = pkg.tags || [];
      for (const t of tags) {
        const cb = form.querySelector<HTMLInputElement>(
          `input[name="tags"][value="${CSS.escape(t)}"]`
        );
        if (cb) cb.checked = true;
      }
      loading.classList.add('hidden');
      form.classList.remove('hidden');
    } catch (err) {
      console.error(err);
      loading.classList.add('hidden');
      errorBox.classList.remove('hidden');
      errorBox.textContent = 'Could not load this package.';
    }
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const payload = {
      description: data.get('description'),
      tags: data.getAll('tags') as string[],
    };
    status.classList.remove('hidden');
    status.textContent = 'Saving…';
    try {
      await pb.collection('packages').update(id, payload);
      status.textContent = 'Saved.';
      setTimeout(() => (location.href = '/me/packages'), 800);
    } catch (err: any) {
      console.error(err);
      status.textContent = formatPbError(err, 'Save failed.');
    }
  });

  deleteBtn?.addEventListener('click', async () => {
    if (!confirm('Delete this package? This cannot be undone.')) return;
    try {
      await pb.collection('packages').delete(id);
      location.href = '/me/packages';
    } catch (err: any) {
      console.error(err);
      status.classList.remove('hidden');
      status.textContent = formatPbError(err, 'Delete failed.');
    }
  });
</script>
