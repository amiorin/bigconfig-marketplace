---
import Layout from '~/layouts/Layout.astro';
---

<Layout title="My packages — BigConfig Marketplace">
  <section class="mx-auto max-w-6xl px-6 pt-20 pb-12">
    <div class="flex flex-wrap items-end justify-between gap-4">
      <div>
        <div
          class="mb-4 inline-block text-xs font-semibold tracking-widest text-yellow-400 uppercase"
        >
          My packages
        </div>
        <h1
          class="text-4xl font-semibold tracking-tight text-white md:text-5xl"
        >
          Your submissions.
        </h1>
        <p id="user-line" class="mt-2 text-sm text-neutral-500"></p>
      </div>
      <div class="flex gap-3">
        <a
          href="/submit"
          class="rounded-full bg-yellow-400 px-5 py-2.5 text-sm font-semibold text-neutral-950 hover:bg-yellow-300"
          >Add</a
        >
        <a
          href="/me/applications"
          class="rounded-full border border-neutral-700 px-5 py-2.5 text-sm font-semibold text-neutral-200 hover:border-neutral-500 hover:text-white"
          >My applications</a
        >
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-6 pb-24">
    <div
      id="auth-gate"
      class="hidden rounded-2xl border border-neutral-800 bg-neutral-900/40 p-10 text-center"
    >
      <p class="text-neutral-300">Sign in to see your submissions.</p>
      <a
        href="/login?next=/me/packages"
        class="mt-6 inline-block rounded-full bg-yellow-400 px-6 py-3 text-sm font-semibold text-neutral-950 hover:bg-yellow-300"
        >Sign in with Google</a
      >
    </div>
    <div id="loading" class="text-center text-neutral-500">Loading…</div>
    <div id="empty" class="hidden text-center text-neutral-400">
      <p>You haven't added any packages yet.</p>
      <a
        href="/submit"
        class="mt-6 inline-block rounded-full bg-yellow-400 px-6 py-3 text-sm font-semibold text-neutral-950 hover:bg-yellow-300"
        >Add one</a
      >
    </div>
    <div id="grid" class="hidden grid gap-6 md:grid-cols-2 lg:grid-cols-3"></div>
  </section>
</Layout>

<script>
  import PocketBase from 'pocketbase';

  const pb = new PocketBase(import.meta.env.PUBLIC_PB_URL || '');
  const gate = document.getElementById('auth-gate')!;
  const loading = document.getElementById('loading')!;
  const empty = document.getElementById('empty')!;
  const grid = document.getElementById('grid')!;
  const userLine = document.getElementById('user-line')!;

  function statusPill(status: string): string {
    const base =
      'inline-flex items-center rounded-full px-2 py-0.5 text-[10px] font-semibold tracking-widest uppercase';
    if (status === 'approved')
      return `<span class="${base} bg-green-400/10 text-green-300 ring-1 ring-green-400/20">approved</span>`;
    if (status === 'rejected')
      return `<span class="${base} bg-red-400/10 text-red-300 ring-1 ring-red-400/20">rejected</span>`;
    return `<span class="${base} bg-yellow-400/10 text-yellow-400 ring-1 ring-yellow-400/20">pending review</span>`;
  }

  function escape(s: string): string {
    return String(s ?? '').replace(/[&<>"']/g, (c) =>
      ({
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        '"': '&quot;',
        "'": '&#39;',
      })[c]!
    );
  }

  async function load() {
    if (!pb.authStore.isValid) {
      loading.classList.add('hidden');
      gate.classList.remove('hidden');
      return;
    }
    const me = pb.authStore.record;
    userLine.textContent = `Signed in as ${me?.name || me?.email || me?.id}.`;
    try {
      const records = await pb.collection('packages').getFullList({
        filter: `submitter = "${me?.id}"`,
        sort: '-created',
      });
      loading.classList.add('hidden');
      if (records.length === 0) {
        empty.classList.remove('hidden');
        return;
      }
      grid.classList.remove('hidden');
      grid.innerHTML = records
        .map((p: any) => {
          const tags = (p.tags || [])
            .map(
              (t: string) =>
                `<span class="rounded-full bg-neutral-800/80 px-2.5 py-0.5 text-xs text-neutral-300">${escape(t)}</span>`
            )
            .join('');
          return `
          <div class="flex flex-col rounded-2xl border border-neutral-800 bg-neutral-900/40 p-8">
            <div class="flex items-start justify-between gap-4">
              <h3 class="text-xl font-semibold text-white">${escape(p.name)}</h3>
              ${statusPill(p.status)}
            </div>
            <p class="mt-4 flex-1 text-sm leading-relaxed text-neutral-400">${escape(p.description || '')}</p>
            <div class="mt-5 flex flex-wrap gap-2">${tags}</div>
            <div class="mt-6 flex gap-3">
              <a href="/me/edit?id=${p.id}" class="rounded-full border border-neutral-700 px-4 py-1.5 text-xs font-semibold text-neutral-200 hover:border-yellow-400 hover:text-yellow-400">Edit</a>
              <a href="${escape(p.github_url)}" target="_blank" rel="noopener" class="rounded-full border border-neutral-700 px-4 py-1.5 text-xs font-semibold text-neutral-200 hover:border-yellow-400 hover:text-yellow-400">GitHub</a>
            </div>
          </div>`;
        })
        .join('');
    } catch (err) {
      console.error(err);
      loading.textContent = 'Could not load your packages.';
    }
  }

  load();
</script>
