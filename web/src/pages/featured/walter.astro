---
import Layout from '~/layouts/Layout.astro';
import Tabs from '~/components/Tabs.astro';
import TabItem from '~/components/TabItem.astro';

const features = [
  {
    title: 'Any cloud',
    body: 'Hetzner Cloud, Oracle Cloud Infrastructure, or bring your own server. Swap providers in bb.edn — the dev environment stays identical.',
    icon: 'M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z',
  },
  {
    title: 'One-command provisioning',
    body: '`bb walter create` spins up the VM, runs Ansible, installs devbox, clones your repos, hands you a ready box. `bb walter delete` tears it down.',
    icon: 'M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z',
  },
  {
    title: 'Reproducible toolchain',
    body: "Declare your team's languages, runtimes, and CLIs once. Devbox installs them pinned and reproducible — identical across every engineer's box.",
    icon: 'M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4',
  },
  {
    title: 'Personalized shell, by default',
    body: 'Doom Emacs, Zellij, Fish, Atuin — codified once, installed everywhere. New hires get the team standard the moment the box finishes provisioning.',
    icon: 'M13 10V3L4 14h7v7l9-11h-7z',
  },
  {
    title: 'Repos & worktrees pre-cloned',
    body: "Your team's repositories arrive on the box with worktrees already set up for the branches you work on. No first-day dance to get to code.",
    icon: 'M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4.586a1 1 0 01.707.293l4.414 4.414a1 1 0 01.293.707V15a2 2 0 01-2 2h-2M8 7H6a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2v-2',
  },
  {
    title: 'Ansible-managed host',
    body: 'Users, SSH keys, firewall rules, base packages — every machine-level concern codified as a playbook, not a runbook in a wiki.',
    icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
  },
];

const comparison = [
  {
    axis: 'Infrastructure',
    gcw: 'GCP only',
    walter: 'Any cloud — Hetzner, OCI, or BYO server',
  },
  {
    axis: 'Pricing model',
    gcw: 'Per-seat, per-hour through GCP',
    walter: 'The cost of your own VM — no markup',
  },
  {
    axis: 'Toolchain',
    gcw: 'Container images you build, push, and maintain',
    walter: 'Declarative devbox.json, Nix-pinned',
  },
  {
    axis: 'Shell & editors',
    gcw: "Whatever's baked into the image",
    walter: 'Doom Emacs, Zellij, Fish, Atuin — codified',
  },
  {
    axis: 'Data residency',
    gcw: "Google's regions",
    walter: 'Your provider, your region, your jurisdiction',
  },
  {
    axis: 'Ops surface',
    gcw: 'GCP console, IAM, gcloud',
    walter: '`bb walter` — agent-operable from a prompt',
  },
  {
    axis: 'Lock-in',
    gcw: 'GCP-native configuration',
    walter: 'Portable bb.edn + Ansible, runs anywhere',
  },
  {
    axis: 'Air-gapped / on-prem',
    gcw: 'Not supported',
    walter: 'Supported via BYO server',
  },
];

const planMd = `You need to create a project to provision a cloud dev environment for your team.
This project contains only the \`bb.edn\` file.
The \`bb.edn\` contains the dependency https://github.com/amiorin/walter
You can download https://github.com/amiorin/walter to see how it works.
https://github.com/amiorin/walter is built on top of https://github.com/amiorin/big-config
All the options should be defined in the \`bb.edn\`.
Only the \`walter\` task should be created.
The compute provider is Hetzner with 8 GB RAM, 4 vCPUs, 80 GB disk.
Each team member gets a user with their SSH public key.
The devbox toolchain includes the languages and CLIs your team uses.
Your team's dotfiles repository is cloned into every user's home.
Your team's project repositories are cloned with worktrees for active branches.
Personalized environment includes Doom Emacs, Zellij, Fish, and Atuin.
You need to create the \`.envrc\` for HCLOUD_TOKEN — I will provide the value later.`;

const bbEdn = `{:deps  {io.github.amiorin/walter {:git/url "https://github.com/amiorin/walter"
                                    :git/sha "REPLACE_WITH_LATEST_SHA"}}
 :tasks {:requires ([io.github.amiorin.walter.package :as pkg])
         walter    {:doc  "bb walter create | bb walter delete"
                    :task (pkg/walter*
                           *command-line-args*
                           {:big-config.render/profile "team-dev"
                            :big-config.workflow/params
                            {:provider-compute   "hcloud"
                             :hcloud-server-type "cax31"
                             :hcloud-location    "nbg1"
                             :hcloud-image       "ubuntu-24.04"
                             :hcloud-ssh-keys    ["id_ed25519"]

                             :walter
                             {:users        [{:name    "<teammate>"
                                              :ssh-key "<public-key>"}]
                              :dotfiles     "git@github.com:<org>/dotfiles"
                              :repositories [{:url       "git@github.com:<org>/<repo>"
                                              :worktrees ["main" "develop"]}]
                              :devbox       {:packages ["<language>" "<cli>"]}
                              :tools        [:doom-emacs :zellij :fish :atuin]}

                             :provider-backend "s3"}})}}}`;

const runSh = `$ bb walter create

$ bb walter delete`;
---

<Layout
  title="BigConfig walter — Standardized cloud dev environments for your team"
  description="Walter provisions consistent, high-productivity cloud dev boxes on any infrastructure — Hetzner, OCI, or bring your own. Like Google Cloud Workstations, with your team's toolchain, your team's data, your team's bill."
  gradient="blue"
>
  <section class="mx-auto max-w-6xl px-6 pt-20 pb-28 text-center">
    <div
      class="mb-6 inline-flex items-center gap-2 rounded-full border border-neutral-800 bg-neutral-900/60 px-4 py-1.5 text-xs font-medium text-neutral-300"
    >
      <span class="h-1.5 w-1.5 rounded-full bg-[#62e1e9]"></span>
      BigConfig package · Walter
    </div>
    <h1
      class="mx-auto max-w-4xl text-5xl font-semibold tracking-tight text-white md:text-7xl"
    >
      Cloud dev environments,<br />
      <span
        class="bg-gradient-to-r from-[#62e1e9] via-[#3a8cec] to-[#0652e9] bg-clip-text text-transparent"
        >standardized for your team.</span
      >
    </h1>
    <p class="mx-auto mt-6 max-w-2xl text-lg text-neutral-300 md:text-xl">
      Provision consistent, high-productivity dev boxes for every engineer on
      your team — on any infrastructure. Walter sets up the machine, installs
      the toolchain, clones your repos, and leaves a personalized environment
      your agent can manage.
    </p>
    <div
      class="mx-auto mt-10 flex max-w-md flex-col items-stretch justify-center gap-4 px-4 sm:max-w-none sm:flex-row sm:items-center sm:px-0"
    >
      <a
        href="#deploy"
        class="rounded-full bg-[#0652e9] px-8 py-4 text-center text-base font-semibold text-white transition hover:bg-[#1e6cf3]"
      >
        Get started →
      </a>
      <a
        href="https://github.com/amiorin/walter"
        class="rounded-full border border-neutral-700 px-8 py-4 text-center text-base font-semibold text-neutral-200 transition hover:border-neutral-500 hover:text-white"
      >
        View on GitHub
      </a>
    </div>
    <p class="mt-6 text-sm text-neutral-500">
      Like Google Cloud Workstations — on any cloud, with your team's software.
    </p>
  </section>

  <section class="mx-auto max-w-6xl px-6 py-12">
    <div
      class="grid grid-cols-2 gap-px overflow-hidden rounded-2xl border border-neutral-800 bg-neutral-800 md:grid-cols-4"
    >
      {
        [
          ['Any', 'cloud, any toolchain'],
          ['1', 'command per box'],
          ['Nix', 'reproducible toolchain'],
          ['Yours', 'infra, data, bill'],
        ].map(([stat, label]) => (
          <div class="bg-neutral-950 p-6 text-center">
            <div class="text-3xl font-semibold text-white md:text-4xl">{stat}</div>
            <div class="mt-2 text-xs uppercase tracking-wider text-neutral-400">{label}</div>
          </div>
        ))
      }
    </div>
  </section>

  <section id="features" class="mx-auto max-w-6xl px-6 py-24">
    <div class="mb-16 text-center">
      <div
        class="mb-4 inline-block text-xs font-semibold uppercase tracking-widest text-[#62e1e9]"
      >
        What you get
      </div>
      <h2 class="text-4xl font-semibold tracking-tight text-white md:text-5xl">
        A team standard,<br />not a wiki page.
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-neutral-400">
        The BigConfig walter package codifies every decision — host specs,
        toolchain, dotfiles, repos, access — as a declarative Clojure config
        your team can clone, version, and ship to any cloud.
      </p>
    </div>

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        features.map((f) => (
          <div class="group rounded-2xl border border-neutral-800 bg-neutral-900/40 p-8 transition hover:border-[#62e1e9]/40 hover:bg-neutral-900">
            <div class="mb-5 inline-flex h-11 w-11 items-center justify-center rounded-lg bg-[#62e1e9]/10 text-[#62e1e9] ring-1 ring-[#62e1e9]/20">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-5 w-5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d={f.icon} />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-white">{f.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-neutral-400">{f.body}</p>
          </div>
        ))
      }
    </div>
  </section>

  <section id="compare" class="mx-auto max-w-6xl px-6 py-24">
    <div class="mb-12 text-center">
      <div
        class="mb-4 inline-block text-xs font-semibold uppercase tracking-widest text-[#62e1e9]"
      >
        Walter vs Google Cloud Workstations
      </div>
      <h2 class="text-4xl font-semibold tracking-tight text-white md:text-5xl">
        Same idea.<br />Different shape.
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-neutral-400">
        Cloud Workstations standardizes dev environments — on Google's terms.
        Walter does the same job on your infrastructure, with your software,
        on your bill.
      </p>
    </div>

    <div
      class="overflow-hidden rounded-2xl border border-neutral-800 bg-neutral-900/40"
    >
      <div class="hidden grid-cols-3 border-b border-neutral-800 bg-neutral-950/60 px-6 py-4 text-xs font-semibold uppercase tracking-widest text-neutral-400 md:grid">
        <div></div>
        <div>Google Cloud Workstations</div>
        <div class="text-[#62e1e9]">BigConfig Walter</div>
      </div>
      {
        comparison.map((row, idx) => (
          <div
            class:list={[
              'grid grid-cols-1 gap-2 px-6 py-5 md:grid-cols-3 md:gap-6',
              idx !== comparison.length - 1 ? 'border-b border-neutral-800' : '',
            ]}
          >
            <div class="text-sm font-semibold text-white">{row.axis}</div>
            <div class="text-sm text-neutral-400">
              <span class="mr-2 inline-block text-[10px] font-semibold uppercase tracking-widest text-neutral-500 md:hidden">
                Cloud Workstations
              </span>
              {row.gcw}
            </div>
            <div class="text-sm text-neutral-200">
              <span class="mr-2 inline-block text-[10px] font-semibold uppercase tracking-widest text-[#62e1e9] md:hidden">
                Walter
              </span>
              {row.walter}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <section id="deploy" class="mx-auto max-w-6xl px-6 py-24">
    <div class="mb-12 text-center">
      <div
        class="mb-4 inline-block text-xs font-semibold uppercase tracking-widest text-[#62e1e9]"
      >
        Deploy with your agent
      </div>
      <h2 class="text-4xl font-semibold tracking-tight text-white md:text-5xl">
        Describe it.<br />Your agent writes the config.
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-neutral-400">
        Describe the team environment in plain English. Your agent refines the
        plan, writes a single <code
          class="rounded bg-neutral-800 px-1.5 py-0.5 font-mono text-sm text-[#62e1e9]"
          >bb.edn</code
        >, and runs it.
      </p>
    </div>

    <div
      class="code-tabs overflow-hidden rounded-2xl border border-neutral-800 bg-neutral-900/40"
    >
      <Tabs>
        <TabItem label="plan.md">
          <pre class="overflow-x-auto text-sm leading-relaxed"><code class="font-mono text-neutral-300">{planMd}</code></pre>
        </TabItem>
        <TabItem label="bb.edn">
          <pre class="overflow-x-auto text-sm leading-relaxed"><code class="font-mono text-neutral-300">{bbEdn}</code></pre>
        </TabItem>
        <TabItem label="Run">
          <pre class="overflow-x-auto text-sm leading-relaxed"><code class="font-mono text-neutral-300">{runSh}</code></pre>
        </TabItem>
      </Tabs>
    </div>
  </section>

  <section id="how" class="mx-auto max-w-6xl px-6 py-24">
    <div class="rounded-3xl border border-neutral-800 bg-neutral-900/40 p-10 md:p-16">
      <div
        class="mb-4 text-xs font-semibold uppercase tracking-widest text-[#62e1e9]"
      >
        How it works
      </div>
      <h2 class="max-w-3xl text-3xl font-semibold tracking-tight text-white md:text-4xl">
        Three steps from empty cloud account to working dev box.
      </h2>
      <ol class="mt-12 grid list-none gap-10 pl-0 md:grid-cols-3">
        <li>
          <div class="mb-3 text-sm font-semibold text-[#62e1e9]">01 — Describe</div>
          <h3 class="text-lg font-semibold text-white">Tell your agent what the team needs</h3>
          <p class="mt-2 text-sm text-neutral-400">
            Which cloud, what size box, which toolchain, which repos. The
            agent turns the conversation into a single <code class="rounded bg-neutral-800 px-1 py-0.5 font-mono text-xs text-[#62e1e9]">bb.edn</code>.
          </p>
        </li>
        <li>
          <div class="mb-3 text-sm font-semibold text-[#62e1e9]">02 — Provision</div>
          <h3 class="text-lg font-semibold text-white">Ship it to your infrastructure</h3>
          <p class="mt-2 text-sm text-neutral-400">
            <code class="rounded bg-neutral-800 px-1 py-0.5 font-mono text-xs text-[#62e1e9]">bb walter create</code>
            provisions the VM, configures users and firewall, installs devbox,
            clones your repos, and hands you an SSH endpoint.
          </p>
        </li>
        <li>
          <div class="mb-3 text-sm font-semibold text-[#62e1e9]">03 — Operate</div>
          <h3 class="text-lg font-semibold text-white">Hand ops over to the agent</h3>
          <p class="mt-2 text-sm text-neutral-400">
            Upgrades, rebuilds, teardown — every runbook is a BigConfig
            workflow your agent can execute on behalf of the team.
          </p>
        </li>
      </ol>
    </div>
  </section>
</Layout>

<style is:global>
  .code-tabs {
    --sl-color-text-accent: #62e1e9;
    --sl-color-gray-3: rgb(163, 163, 163);
    --sl-color-gray-5: rgb(38, 38, 38);
    --sl-color-white: #fff;
    --sl-line-height-headings: 1.4;
    --sl-outline-offset-inside: -2px;
  }
  .code-tabs sl-tabs {
    display: block;
  }
  .code-tabs .tablist-wrapper {
    background: rgba(10, 10, 10, 0.6);
    border-bottom: 1px solid rgb(38, 38, 38);
    margin: 0;
  }
  .code-tabs [role='tablist'] {
    border-bottom: 0;
    padding: 0;
    margin: 0;
  }
  .code-tabs [role='tab'] {
    color: rgb(163, 163, 163);
    padding: 0.75rem 1.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    border-bottom-width: 2px;
  }
  .code-tabs [role='tab'][aria-selected='true'] {
    color: #fff;
    background: rgba(23, 23, 23, 0.6);
    border-color: #62e1e9;
  }
  .code-tabs [role='tab']:hover:not([aria-selected='true']) {
    color: #fff;
    background: rgba(23, 23, 23, 0.6);
  }
  .code-tabs [role='tabpanel'] {
    padding: 1.5rem;
    margin-top: 0;
  }
  @media (min-width: 768px) {
    .code-tabs [role='tabpanel'] {
      padding: 2rem;
    }
  }
  .code-tabs pre {
    margin: 0;
  }
</style>
