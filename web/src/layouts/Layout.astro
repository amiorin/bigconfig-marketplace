---
import '~/styles/global.css';
import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Made with BigConfig',
  description = 'A community marketplace of BigConfig packages — Clojure projects built on big-config.',
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body class="bg-neutral-950 text-neutral-100 antialiased">
    <div
      class="pointer-events-none fixed inset-0 -z-10 bg-[radial-gradient(ellipse_at_top,_rgba(250,204,21,0.15),_transparent_60%)]"
    >
    </div>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
