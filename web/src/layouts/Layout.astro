---
import '~/styles/global.css';
import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  gradient?: 'yellow' | 'blue';
}

const {
  title = 'BigConfig Marketplace',
  description = 'A community marketplace of BigConfig packages — Clojure projects built on big-config.',
  gradient = 'yellow',
} = Astro.props;

const gradientClass =
  gradient === 'blue'
    ? 'bg-[radial-gradient(ellipse_at_top,_rgba(6,82,233,0.15),_transparent_60%)]'
    : 'bg-[radial-gradient(ellipse_at_top,_rgba(250,204,21,0.15),_transparent_60%)]';
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-4VKP1WY4QJ"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      gtag('js', new Date());
      gtag('config', 'G-4VKP1WY4QJ');
    </script>
  </head>
  <body class="bg-neutral-950 text-neutral-100 antialiased">
    <div class:list={['pointer-events-none fixed inset-0 -z-10', gradientClass]}></div>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
