---
import TagChip from './TagChip.astro';
import type { PackageRecord } from '~/lib/pb';
import { ownerRepo } from '~/lib/packages';

interface Props {
  pkg: PackageRecord;
  highlighted?: boolean;
  showType?: boolean;
}

const { pkg, highlighted = false, showType = false } = Astro.props;
const { owner, repo } = ownerRepo(pkg.name);
const submitterName = pkg.expand?.submitter?.name || pkg.expand?.submitter?.id || 'unknown';
---

<a
  href={`/packages/${owner}/${repo}`}
  class:list={[
    'relative flex flex-col overflow-hidden rounded-2xl border p-8 transition',
    highlighted
      ? 'border-yellow-400/30 bg-yellow-400/5 hover:border-yellow-400/60 hover:bg-yellow-400/10'
      : showType
        ? 'border-yellow-400/25 bg-yellow-400/[0.04] hover:border-yellow-400/50 hover:bg-yellow-400/[0.07]'
        : 'border-neutral-800 bg-neutral-900/40 hover:border-yellow-400/40 hover:bg-neutral-900',
  ]}
>
  {
    showType && (
      <>
        <div
          aria-hidden="true"
          class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-yellow-300 to-orange-500"
        />
        <div class="mb-4">
          <span class="inline-flex items-center gap-2 rounded-full border border-yellow-400/30 bg-yellow-400/10 px-2.5 py-1 text-[11px] font-semibold tracking-wider text-yellow-300 uppercase">
            <span class="h-1.5 w-1.5 rounded-full bg-yellow-300" />
            Package
          </span>
        </div>
      </>
    )
  }
  <div class="flex items-start justify-between gap-4">
    <div>
      <h3 class="text-xl font-semibold text-white">{pkg.name}</h3>
      <div class="mt-1 text-xs text-neutral-500">
        submitted by {submitterName}
      </div>
    </div>
    {
      pkg.stars > 0 && (
        <div class="flex items-center gap-1 text-xs text-neutral-400">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-3.5 w-3.5"
            viewBox="0 0 24 24"
            fill="currentColor"
          >
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77 5.82 21l1.18-6.88-5-4.87 6.91-1.01z" />
          </svg>
          {pkg.stars}
        </div>
      )
    }
  </div>
  <p class="mt-4 flex-1 text-sm leading-relaxed text-neutral-400">
    {pkg.description}
  </p>
  {
    pkg.tags && pkg.tags.length > 0 && (
      <div class="mt-5 flex flex-wrap gap-2">
        {pkg.tags.map((t) => <TagChip tag={t} />)}
      </div>
    )
  }
</a>
