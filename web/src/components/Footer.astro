  <nav class="mb-6 flex flex-wrap items-center justify-center gap-x-6 gap-y-2">
    <a
      href="/submit"
      class="text-neutral-300 transition hover:text-yellow-400"
      >Submit a package</a
    >
    <span aria-hidden="true" class="text-neutral-700">·</span>
    <a
      href="/applications/submit"
      class="text-neutral-300 transition hover:text-yellow-400"
      >Submit an application</a
    >
  </nav>
  © {year} Made with BigConfig · <a
    href="https://bigconfig.it/"
    class="text-white hover:text-neutral-300">bigconfig.it</a
  >
</footer>
