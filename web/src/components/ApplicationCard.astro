---
import TagChip from './TagChip.astro';
import type { ApplicationRecord } from '~/lib/pb';
import { ownerRepo } from '~/lib/packages';

interface Props {
  app: ApplicationRecord;
  highlighted?: boolean;
}

const { app, highlighted = false } = Astro.props;
const { owner, repo } = ownerRepo(app.name);
const submitterName = app.expand?.submitter?.name || app.expand?.submitter?.id || 'unknown';
---

<a
  href={`/applications/${owner}/${repo}`}
  class:list={[
    'flex flex-col rounded-2xl border p-8 transition',
    highlighted
      ? 'border-yellow-400/30 bg-yellow-400/5 hover:border-yellow-400/60 hover:bg-yellow-400/10'
      : 'border-neutral-800 bg-neutral-900/40 hover:border-yellow-400/40 hover:bg-neutral-900',
  ]}
>
  <div class="flex items-start justify-between gap-4">
    <div>
      <h3 class="text-xl font-semibold text-white">{app.name}</h3>
      <div class="mt-1 text-xs text-neutral-500">by {submitterName}</div>
    </div>
    {
      app.stars > 0 && (
        <div class="flex items-center gap-1 text-xs text-neutral-400">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-3.5 w-3.5"
            viewBox="0 0 24 24"
            fill="currentColor"
          >
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77 5.82 21l1.18-6.88-5-4.87 6.91-1.01z" />
          </svg>
          {app.stars}
        </div>
      )
    }
  </div>
  <p class="mt-4 flex-1 text-sm leading-relaxed text-neutral-400">
    {app.description}
  </p>
  <div class="mt-4 font-mono text-xs text-neutral-500 truncate">{app.docker_image}</div>
  {
    app.tags && app.tags.length > 0 && (
      <div class="mt-5 flex flex-wrap gap-2">
        {app.tags.map((t) => <TagChip tag={t} />)}
      </div>
    )
  }
</a>
