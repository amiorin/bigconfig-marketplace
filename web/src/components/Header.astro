---
import logo from '~/assets/logo.svg';

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path === href || path.startsWith(href + '/');
---

<div
  class="sticky top-0 z-50 border-b border-neutral-800/80 bg-neutral-950/85 backdrop-blur-md"
>
  <header class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
    <a href="https://www.bigconfig.ai" aria-label="BigConfig" class="flex items-center">
      <img src={logo.src} alt="" class="h-7 w-auto" />
    </a>
    <nav class="hidden gap-8 text-sm md:flex">
      <a
        href="/"
        class="text-white transition hover:text-yellow-400">Marketplace</a
      >
      <a
        href="/packages"
        class:list={[
          'transition hover:text-yellow-400',
          isActive('/packages') ? 'text-yellow-400' : 'text-white',
        ]}>Packages</a
      >
      <a
        href="/applications"
        class:list={[
          'transition hover:text-yellow-400',
          isActive('/applications') ? 'text-yellow-400' : 'text-white',
        ]}>Applications</a
      >
      <a
        href="/documentation"
        class:list={[
          'transition hover:text-yellow-400',
          isActive('/documentation') ? 'text-yellow-400' : 'text-white',
        ]}>Documentation</a
      >
    </nav>
    <div class="flex items-center gap-3">
      <!-- hamburger (mobile only) -->
      <button
        type="button"
        data-menu-trigger="mobile"
        aria-label="Open menu"
        class="flex items-center justify-center rounded-md p-1.5 text-neutral-400 transition hover:text-white md:hidden"
      >
        <svg data-hamburger-icon class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M2 4.75A.75.75 0 012.75 4h14.5a.75.75 0 010 1.5H2.75A.75.75 0 012 4.75zM2 10a.75.75 0 01.75-.75h14.5a.75.75 0 010 1.5H2.75A.75.75 0 012 10zm0 5.25a.75.75 0 01.75-.75h14.5a.75.75 0 010 1.5H2.75a.75.75 0 01-.75-.75z" clip-rule="evenodd" />
        </svg>
        <svg data-close-icon class="hidden h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path d="M6.28 5.22a.75.75 0 00-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 101.06 1.06L10 11.06l3.72 3.72a.75.75 0 101.06-1.06L11.06 10l3.72-3.72a.75.75 0 00-1.06-1.06L10 8.94 6.28 5.22z" />
        </svg>
      </button>
      <!-- desktop auth (hidden on mobile) -->
      <div class="relative hidden md:block">
        <a
          href="/login"
          data-user-signin
          class="rounded-full border border-neutral-700 px-4 py-2 text-sm font-semibold text-neutral-200 transition hover:border-neutral-500 hover:text-white"
          >Sign in</a
        >
        <button
          type="button"
          data-menu-trigger="user"
          data-user-button
          class="hidden items-center rounded-full border border-neutral-700 p-0.5 text-sm font-medium text-neutral-200 transition hover:border-neutral-500 hover:text-white"
        >
          <span
            data-user-avatar
            class="inline-flex h-7 w-7 items-center justify-center overflow-hidden rounded-full bg-neutral-700 text-xs font-semibold text-white"
          ></span>
        </button>
        <div
          data-menu-panel="user"
          class="absolute right-0 mt-2 hidden w-48 overflow-hidden rounded-xl border border-neutral-800 bg-neutral-900 shadow-lg"
        >
          <a
            href="/me/packages"
            class:list={[
              'block px-4 py-2.5 text-sm transition hover:bg-neutral-800 hover:text-yellow-400',
              isActive('/me/packages') ? 'text-yellow-400' : 'text-neutral-200',
            ]}>My packages</a
          >
          <a
            href="/me/applications"
            class:list={[
              'block px-4 py-2.5 text-sm transition hover:bg-neutral-800 hover:text-yellow-400',
              isActive('/me/applications') ? 'text-yellow-400' : 'text-neutral-200',
            ]}>My applications</a
          >
          <button
            type="button"
            data-user-signout
            class="block w-full border-t border-neutral-800 px-4 py-2.5 text-left text-sm text-neutral-200 transition hover:bg-neutral-800 hover:text-yellow-400"
            >Sign out</button
          >
        </div>
      </div>
    </div>
  </header>
  <!-- mobile nav drawer -->
  <div
    data-menu-panel="mobile"
    class="hidden border-t border-neutral-800 px-6 pb-4 md:hidden"
  >
    <nav class="flex flex-col gap-1 pt-3 text-sm">
      <a
        href="/"
        class="rounded-lg px-3 py-2 text-white transition hover:bg-neutral-800 hover:text-yellow-400"
        >Marketplace</a
      >
      <a
        href="/packages"
        class:list={[
          'rounded-lg px-3 py-2 transition hover:bg-neutral-800 hover:text-yellow-400',
          isActive('/packages') ? 'text-yellow-400' : 'text-white',
        ]}>Packages</a
      >
      <a
        href="/applications"
        class:list={[
          'rounded-lg px-3 py-2 transition hover:bg-neutral-800 hover:text-yellow-400',
          isActive('/applications') ? 'text-yellow-400' : 'text-white',
        ]}>Applications</a
      >
      <a
        href="/documentation"
        class:list={[
          'rounded-lg px-3 py-2 transition hover:bg-neutral-800 hover:text-yellow-400',
          isActive('/documentation') ? 'text-yellow-400' : 'text-white',
        ]}>Documentation</a
      >
    </nav>
    <!-- mobile auth section -->
    <div class="mt-2 border-t border-neutral-800 pt-3 text-sm">
      <a
        href="/login"
        data-mobile-signin
        class="block rounded-lg px-3 py-2 font-semibold text-neutral-200 transition hover:bg-neutral-800 hover:text-white"
        >Sign in</a
      >
      <div data-mobile-user-section class="hidden flex-col gap-1">
        <div class="flex items-center gap-3 px-3 py-2">
          <span
            data-mobile-user-avatar
            class="inline-flex h-8 w-8 flex-shrink-0 items-center justify-center overflow-hidden rounded-full bg-neutral-700 text-xs font-semibold text-white"
          ></span>
        </div>
        <a
          href="/me/packages"
          class:list={[
            'rounded-lg px-3 py-2 transition hover:bg-neutral-800 hover:text-yellow-400',
            isActive('/me/packages') ? 'text-yellow-400' : 'text-neutral-200',
          ]}>My packages</a
        >
        <a
          href="/me/applications"
          class:list={[
            'rounded-lg px-3 py-2 transition hover:bg-neutral-800 hover:text-yellow-400',
            isActive('/me/applications') ? 'text-yellow-400' : 'text-neutral-200',
          ]}>My applications</a
        >
        <button
          type="button"
          data-mobile-signout
          class="rounded-lg px-3 py-2 text-left text-neutral-200 transition hover:bg-neutral-800 hover:text-yellow-400"
          >Sign out</button
        >
      </div>
    </div>
  </div>
</div>

<script>
  import PocketBase from 'pocketbase';

  const pb = new PocketBase(import.meta.env.PUBLIC_PB_URL || '');

  const signInLink = document.querySelector('[data-user-signin]') as HTMLElement | null;
  const userButton = document.querySelector('[data-user-button]') as HTMLElement | null;
  const userAvatar = document.querySelector('[data-user-avatar]') as HTMLElement | null;
  const signoutBtn = document.querySelector('[data-user-signout]') as HTMLElement | null;

  const mobileSignIn = document.querySelector('[data-mobile-signin]') as HTMLElement | null;
  const mobileUserSection = document.querySelector('[data-mobile-user-section]') as HTMLElement | null;
  const mobileUserAvatar = document.querySelector('[data-mobile-user-avatar]') as HTMLElement | null;
  const mobileSignoutBtn = document.querySelector('[data-mobile-signout]') as HTMLElement | null;

  function makeAvatar(avatarUrl: string, displayName: string, el: HTMLElement) {
    if (avatarUrl) {
      const img = document.createElement('img');
      img.src = avatarUrl;
      img.alt = '';
      img.referrerPolicy = 'no-referrer';
      img.className = 'h-full w-full object-cover';
      el.replaceChildren(img);
    } else {
      el.textContent = (displayName[0] || '?').toUpperCase();
    }
  }

  function hydrateUser() {
    if (!pb.authStore.isValid) return;
    const me = pb.authStore.record as any;
    if (!me) return;

    const displayName =
      me.name || (me.email ? String(me.email).split('@')[0] : 'Account');
    const avatarUrl = localStorage.getItem('user_avatar_url') || '';

    // desktop
    signInLink?.classList.add('hidden');
    if (userButton) {
      userButton.classList.remove('hidden');
      userButton.classList.add('flex');
    }
    if (userAvatar) makeAvatar(avatarUrl, displayName, userAvatar);

    // mobile
    mobileSignIn?.classList.add('hidden');
    if (mobileUserSection) {
      mobileUserSection.classList.remove('hidden');
      mobileUserSection.classList.add('flex');
    }
    if (mobileUserAvatar) makeAvatar(avatarUrl, displayName, mobileUserAvatar);
  }

  hydrateUser();

  const triggers = document.querySelectorAll('[data-menu-trigger]');
  triggers.forEach((trigger) => {
    const name = trigger.getAttribute('data-menu-trigger')!;
    const panel = document.querySelector(
      `[data-menu-panel="${name}"]`
    ) as HTMLElement | null;
    if (!panel) return;
    trigger.addEventListener('click', (e) => {
      e.stopPropagation();
      document.querySelectorAll('[data-menu-panel]').forEach((p) => {
        if (p !== panel) p.classList.add('hidden');
      });
      const isOpen = !panel.classList.contains('hidden');
      panel.classList.toggle('hidden');
      if (name === 'mobile') {
        const hamburger = trigger.querySelector('[data-hamburger-icon]') as HTMLElement | null;
        const close = trigger.querySelector('[data-close-icon]') as HTMLElement | null;
        hamburger?.classList.toggle('hidden', !isOpen ? true : false);
        close?.classList.toggle('hidden', !isOpen ? false : true);
      }
    });
  });

  function closeAll() {
    document.querySelectorAll('[data-menu-panel]').forEach((p) => p.classList.add('hidden'));
    const hamburger = document.querySelector('[data-hamburger-icon]') as HTMLElement | null;
    const close = document.querySelector('[data-close-icon]') as HTMLElement | null;
    hamburger?.classList.remove('hidden');
    close?.classList.add('hidden');
  }

  document.addEventListener('click', closeAll);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeAll(); });

  signoutBtn?.addEventListener('click', () => {
    pb.authStore.clear();
    localStorage.removeItem('user_avatar_url');
    location.href = '/';
  });

  mobileSignoutBtn?.addEventListener('click', () => {
    pb.authStore.clear();
    localStorage.removeItem('user_avatar_url');
    location.href = '/';
  });
</script>
